{
  "version": 2,
  "builds": [
    { "src": "Front/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/", "dest": "/login/index.html" },
    { "src": "/login", "dest": "/login/index.html" },
    { "src": "/login/", "dest": "/login/index.html" },
    { "src": "/admin", "dest": "/admin/admin.html" },
    { "src": "/eventos", "dest": "/eventos/eventos_novo.html" },
    { "src": "/historico", "dest": "/historico/historico.html" },
    { "src": "/cadastro", "dest": "/cadastro/cadastro.html" },
    { "src": "/cadastroUsuarios", "dest": "/cadastroUsuarios/CadastroUsuarios.html" },
    { "src": "/cadastroUsuarios/(.*)", "dest": "/cadastroUsuarios/$1" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
 