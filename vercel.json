{
  "version": 2,
  "builds": [
    { "src": "Front/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/", "dest": "/Front/login/index.html" },
    { "src": "/login", "dest": "/Front/login/index.html" },
    { "src": "/login/", "dest": "/Front/login/index.html" },
    { "src": "/admin", "dest": "/Front/admin/admin.html" },
    { "src": "/eventos", "dest": "/Front/eventos/eventos_novo.html" },
    { "src": "/historico", "dest": "/Front/historico/historico.html" },
    { "src": "/cadastro", "dest": "/Front/cadastro/cadastro.html" },
    { "src": "/cadastroUsuarios", "dest": "/Front/cadastroUsuarios/CadastroUsuarios.html" },
    { "src": "/Front/(.*)", "dest": "/Front/$1" },
    { "src": "/(.*)", "dest": "/Front/$1" }
  ]
}
 